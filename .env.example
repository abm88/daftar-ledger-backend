# Server
NODE_ENV=development
PORT=3000

# PostgreSQL — either a single DATABASE_URL or discrete PG* variables.
# DATABASE_URL takes precedence when set (DigitalOcean Managed Databases provide one).
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=daftar
PGUSER=daftar
PGPASSWORD=daftar
# Set to "require" when connecting to DigitalOcean Managed PostgreSQL
PGSSLMODE=disable

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# CORS — comma-separated list of allowed origins, or * for any
CORS_ORIGINS=*
